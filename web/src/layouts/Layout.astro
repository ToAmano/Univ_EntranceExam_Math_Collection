---
interface Props {
	title: string;
}
const { title } = Astro.props;
---
<!doctype html>
<html lang="ja">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<title>{title}</title>
		<!-- Google Fonts -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&family=Plus+Jakarta+Sans:ital,wght@0,300;0,400;0,500;0,600;0,700;1,400&display=swap" rel="stylesheet">
		<!-- KaTeX CSS for equation rendering -->
		<link
			rel="stylesheet"
			href="https://cdn.jsdelivr.net/npm/katex@0.16.8/dist/katex.min.css"
		/>
		<!-- KaTeX JS for client-side rendering fallback -->
		<script
			defer
			src="https://cdn.jsdelivr.net/npm/katex@0.16.8/dist/katex.min.js"
		></script>
		<script
			defer
			src="https://cdn.jsdelivr.net/npm/katex@0.16.8/dist/contrib/auto-render.min.js"
			onload="renderMathInElement(document.body, {
				delimiters: [
					{left: '$$', right: '$$', display: true},
					{left: '$', right: '$', display: false}
				]
			});"
		></script>
		<style is:global>
			:root {
				--bg-gradient: radial-gradient(circle at 50% 0%, #1a2333 0%, #0d111a 50%, #07090e 100%);
				--primary: #60a5fa;
				--secondary: #34d399;
				--accent: #a78bfa;
				--text-main: #f1f5f9;
				--text-muted: #94a3b8;
				--glass-bg: rgba(17, 24, 39, 0.45);
				--glass-border: rgba(255, 255, 255, 0.06);
				--glass-hover-border: rgba(255, 255, 255, 0.12);
				--glow-color: rgba(96, 165, 250, 0.15);
			}

			body {
				font-family: 'Plus Jakarta Sans', 'Outfit', 'Inter', system-ui, sans-serif;
				background: var(--bg-gradient);
				color: var(--text-main);
				min-height: 100vh;
				margin: 0;
				padding: 0;
				overflow-x: hidden;
				line-height: 1.6;
			}

			/* Glassmorphism card utility */
			.glass {
				background: var(--glass-bg);
				backdrop-filter: blur(16px) saturate(120%);
				-webkit-backdrop-filter: blur(16px) saturate(120%);
				border: 1px solid var(--glass-border);
				border-radius: 16px;
				box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.37);
				transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
			}

			.glass:hover {
				border-color: var(--glass-hover-border);
				transform: translateY(-2px);
				box-shadow: 0 12px 40px 0 rgba(0, 0, 0, 0.5), 0 0 20px 0 var(--glow-color);
			}

			/* Math custom styling */
			.katex-display {
				padding: 1.25rem;
				background: rgba(0, 0, 0, 0.2);
				border-radius: 8px;
				border-left: 3px solid var(--primary);
				overflow-x: auto;
			}
		</style>
	</head>
	<body>
		<main style="max-width: 800px; margin: 0 auto; padding: 3rem 1.5rem;">
			<slot />
		</main>
	</body>
</html>
