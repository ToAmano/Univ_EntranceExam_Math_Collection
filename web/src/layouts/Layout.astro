---
interface Props {
	title: string;
	description?: string;
}

const { title, description = "東大・京大・東工大などの大学入試数学過去問解答アーカイブ。KaTeX描画による高品質な数式と解答解説。" } = Astro.props;
const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<!doctype html>
<html lang="ja">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>{title} | Math Solutions</title>
		<meta name="description" content={description} />
		<link rel="icon" type="image/svg+xml" href={`${baseUrl}/favicon.svg`} />
		
		<!-- Google Fonts -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&family=Plus+Jakarta+Sans:ital,wght@0,300;0,400;0,500;0,600;0,700;1,400&family=Fira+Code:wght@400;500&display=swap" rel="stylesheet">

		<style is:global>
			:root {
				--bg-dark: #07090e;
				--bg-gradient: radial-gradient(circle at 50% -20%, #1e293b 0%, #0f172a 45%, #07090e 100%);
				--primary: #60a5fa;
				--primary-glow: rgba(96, 165, 250, 0.25);
				--secondary: #34d399;
				--accent: #a78bfa;
				--text-main: #f8fafc;
				--text-muted: #94a3b8;
				--text-subtle: #64748b;
				--glass-bg: rgba(15, 23, 42, 0.65);
				--glass-border: rgba(255, 255, 255, 0.08);
				--glass-hover-border: rgba(96, 165, 250, 0.3);
				--card-bg: rgba(30, 41, 59, 0.4);
				--shadow-glow: 0 10px 30px -10px rgba(96, 165, 250, 0.15);
			}

			* {
				box-sizing: border-box;
			}

			body {
				font-family: 'Plus Jakarta Sans', 'Outfit', 'Inter', system-ui, -apple-system, sans-serif;
				background: var(--bg-gradient);
				color: var(--text-main);
				min-height: 100vh;
				margin: 0;
				padding: 0;
				overflow-x: hidden;
				line-height: 1.7;
				display: flex;
				flex-direction: column;
			}

			/* Glassmorphism card utility */
			.glass {
				background: var(--glass-bg);
				backdrop-filter: blur(16px) saturate(130%);
				-webkit-backdrop-filter: blur(16px) saturate(130%);
				border: 1px solid var(--glass-border);
				border-radius: 16px;
				box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.37);
				transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
			}

			.glass-hover {
				transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
			}

			.glass-hover:hover {
				border-color: var(--glass-hover-border);
				transform: translateY(-3px);
				box-shadow: var(--shadow-glow), 0 12px 40px 0 rgba(0, 0, 0, 0.5);
			}

			/* Header Navigation */
			.site-header {
				position: sticky;
				top: 0;
				z-index: 100;
				background: rgba(7, 9, 14, 0.8);
				backdrop-filter: blur(20px);
				-webkit-backdrop-filter: blur(20px);
				border-bottom: 1px solid var(--glass-border);
			}

			.header-inner {
				max-width: 1200px;
				margin: 0 auto;
				padding: 1rem 1.5rem;
				display: flex;
				align-items: center;
				justify-content: space-between;
			}

			.site-logo {
				display: flex;
				align-items: center;
				gap: 0.75rem;
				text-decoration: none;
				color: var(--text-main);
				font-weight: 700;
				font-size: 1.35rem;
				font-family: 'Outfit', sans-serif;
			}

			.logo-badge {
				background: linear-gradient(135deg, #3b82f6, #10b981);
				padding: 0.35rem 0.65rem;
				border-radius: 8px;
				font-size: 0.9rem;
				font-weight: 800;
				color: #ffffff;
				box-shadow: 0 4px 12px rgba(59, 130, 246, 0.3);
			}

			.nav-links {
				display: flex;
				align-items: center;
				gap: 1.5rem;
				list-style: none;
				margin: 0;
				padding: 0;
			}

			.nav-link {
				color: var(--text-muted);
				text-decoration: none;
				font-size: 0.95rem;
				font-weight: 500;
				transition: color 0.2s ease;
			}

			.nav-link:hover {
				color: var(--primary);
			}

			/* Main Content */
			main.main-content {
				flex: 1;
				max-width: 1200px;
				width: 100%;
				margin: 0 auto;
				padding: 2.5rem 1.5rem 4rem;
			}

			/* Footer */
			.site-footer {
				background: rgba(7, 9, 14, 0.95);
				border-top: 1px solid var(--glass-border);
				padding: 2.5rem 1.5rem;
				margin-top: auto;
				color: var(--text-subtle);
				font-size: 0.9rem;
			}

			.footer-inner {
				max-width: 1200px;
				margin: 0 auto;
				display: flex;
				flex-wrap: wrap;
				justify-content: space-between;
				align-items: center;
				gap: 1.5rem;
			}

			/* Math custom styling */
			.katex-display {
				padding: 1.25rem;
				background: rgba(0, 0, 0, 0.3);
				border-radius: 12px;
				border-left: 4px solid var(--primary);
				overflow-x: auto;
				margin: 1.5rem 0;
			}

			/* Markdown Content Container Styles */
			.markdown-body {
				color: #e2e8f0;
				line-height: 1.8;
			}

			.markdown-body h1 {
				font-size: 1.8rem;
				font-weight: 700;
				color: #f8fafc;
				border-bottom: 1px solid rgba(255, 255, 255, 0.1);
				padding-bottom: 0.5rem;
				margin-top: 1.5rem;
				margin-bottom: 1rem;
			}

			.markdown-body h2 {
				font-size: 1.4rem;
				font-weight: 600;
				color: var(--primary);
				margin-top: 1.75rem;
				margin-bottom: 0.75rem;
			}

			.markdown-body h3 {
				font-size: 1.15rem;
				font-weight: 600;
				color: var(--secondary);
				margin-top: 1.5rem;
				margin-bottom: 0.5rem;
			}

			.markdown-body table {
				width: 100%;
				border-collapse: collapse;
				margin: 1.5rem 0;
				background: rgba(0, 0, 0, 0.2);
				border-radius: 10px;
				overflow: hidden;
			}

			.markdown-body th, .markdown-body td {
				padding: 0.75rem 1rem;
				border: 1px solid rgba(255, 255, 255, 0.08);
				text-align: left;
			}

			.markdown-body th {
				background: rgba(255, 255, 255, 0.05);
				color: var(--primary);
				font-weight: 600;
			}

			.markdown-body p {
				margin-bottom: 1rem;
			}

			.markdown-body img {
				max-width: 100%;
				height: auto;
				border-radius: 10px;
				background: rgba(255, 255, 255, 0.95);
				padding: 0.5rem;
				box-shadow: 0 4px 20px rgba(0, 0, 0, 0.4);
			}

			/* Pandoc ::: center container support */
			.markdown-body .center {
				text-align: center;
				margin: 1rem 0;
			}

			/* Custom Badges (High Contrast) */
			.badge {
				display: inline-flex;
				align-items: center;
				padding: 0.3rem 0.75rem;
				border-radius: 9999px;
				font-size: 0.85rem;
				font-weight: 700;
				line-height: 1.2;
				box-shadow: 0 2px 8px rgba(0, 0, 0, 0.25);
			}

			.badge-todai {
				background: rgba(30, 64, 175, 0.5);
				color: #dbeafe;
				border: 1px solid #60a5fa;
			}

			.badge-titech {
				background: rgba(6, 95, 70, 0.5);
				color: #d1fae5;
				border: 1px solid #34d399;
			}

			.badge-summary {
				background: rgba(107, 33, 168, 0.5);
				color: #f3e8ff;
				border: 1px solid #c084fc;
			}

			.badge-problem {
				background: rgba(146, 64, 14, 0.5);
				color: #fef08a;
				border: 1px solid #fbbf24;
			}

			.badge-solution {
				background: rgba(30, 64, 175, 0.5);
				color: #dbeafe;
				border: 1px solid #60a5fa;
			}
		</style>
	</head>
	<body>
		<header class="site-header">
			<div class="header-inner">
				<a href={`${baseUrl}/`} class="site-logo">
					<span class="logo-badge">Math</span>
					<span>Solutions</span>
				</a>
				<nav>
					<ul class="nav-links">
						<li><a href={`${baseUrl}/`} class="nav-link">トップ</a></li>
						<li><a href={`${baseUrl}/#archive`} class="nav-link">過去問アーカイブ</a></li>
						<li>
							<a 
								href="https://github.com/ToAmano/Univ_EntranceExam_Math_Collection" 
								target="_blank" 
								rel="noopener noreferrer" 
								class="nav-link"
							>
								GitHub
							</a>
						</li>
					</ul>
				</nav>
			</div>
		</header>

		<main class="main-content">
			<slot />
		</main>

		<footer class="site-footer">
			<div class="footer-inner">
				<div>
					<div style="font-family: 'Outfit', sans-serif; font-weight: 700; color: var(--text-main); font-size: 1.1rem;">
						Math Solutions
					</div>
					<div style="margin-top: 0.25rem;">大学入試数学 過去問解答アーカイブ (東大・東工大・京大)</div>
				</div>
				<div>
					&copy; {new Date().getFullYear()} Math Solutions Archive. Powered by Astro & KaTeX.
				</div>
			</div>
		</footer>
	</body>
</html>
